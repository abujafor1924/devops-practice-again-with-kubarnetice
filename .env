# PostgreSQL Database Settings
POSTGRES_DB=mydatabase
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_PORT=5435
POSTGRES_HOST=localhost

# Django Settings
DEBUG=True
SECRET_KEY=django-insecure-devops-practice-default-secret-key-1234567890
ALLOWED_HOSTS=localhost,127.0.0.1

# Database URL for Django connection
DATABASE_URL=postgres://myuser:mypassword@localhost:5435/mydatabase

# Redis & Celery Settings
REDIS_PORT=6383
CELERY_BROKER_URL=redis://localhost:6383/0
CELERY_RESULT_BACKEND=redis://localhost:6383/0

# App Settings
APP_PORT=8000

# Nginx Settings
NGINX_PORT=8080
NGINX_SSL_PORT=8443

# Monitoring Settings
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
CADVISOR_PORT=8082
FLOWER_PORT=5555
